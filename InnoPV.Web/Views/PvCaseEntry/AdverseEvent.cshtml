@model List<InnoPV.Web.Models.PvCaseEntry.CaseAdverseEventDetailViewModel>

@{
    ViewData["Title"] = "Adverse Event Details";
    var caseId = (long)ViewBag.PvCaseId;
    var caseNo = Convert.ToString(ViewBag.CaseNo);
    var isReadOnly = Convert.ToBoolean(ViewBag.IsReadOnly ?? false);

    ViewBag.ActiveTab = "AdverseEvent";
}

<div class="container-fluid mt-3">
    @await Html.PartialAsync("_CaseEntryTabs")

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4>Adverse Event Details</h4>
            <p class="text-muted mb-0">
                Case No: <strong>@caseNo</strong>
            </p>
        </div>

        @if (!isReadOnly)
        {
            <a asp-controller="PvCaseEntry"
               asp-action="CreateAdverseEvent"
               asp-route-caseId="@caseId"
               class="btn btn-primary">
                + Add Adverse Event
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Adverse Event List</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Event Term</th>
                        <th>Start Date</th>
                        <th>Stop Date</th>
                        <th>Serious</th>
                        <th>Criteria</th>
                        <th>Severity</th>
                        <th>Outcome</th>
                        <th style="width:100px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var index = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>
                                    <strong>@item.EventTerm</strong>
                                    @if (!string.IsNullOrWhiteSpace(item.EventDescription))
                                    {
                                        <div class="text-muted small">@item.EventDescription</div>
                                    }
                                </td>
                                <td>@(item.EventStartDate.HasValue ? item.EventStartDate.Value.ToString("dd-MMM-yyyy") : "-")</td>
                                <td>@(item.EventStopDate.HasValue ? item.EventStopDate.Value.ToString("dd-MMM-yyyy") : "-")</td>
                                <td>
                                    @if (item.IsSerious)
                                    {
                                        <span class="badge bg-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                                <td>@(item.SeriousnessCriteria ?? "-")</td>
                                <td>@(item.Severity ?? "-")</td>
                                <td>@(item.Outcome ?? "-")</td>
                                <td>
                                    @if (!isReadOnly)
                                    {
                                        <a asp-controller="PvCaseEntry"
                                           asp-action="EditAdverseEvent"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="PvCaseEntry"
                                           asp-action="EditAdverseEvent"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            View
                                        </a>
                                    }
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted">
                                No adverse event records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
