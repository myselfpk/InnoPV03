@model InnoPV.Web.Models.PvCaseEntry.CaseAttachmentUploadViewModel

@{
    ViewData["Title"] = "Upload Attachment";
    ViewBag.PvCaseId = Model.PvCaseId;
    ViewBag.CaseNo = Model.CaseNo;
    ViewBag.ActiveTab = "Attachments";
    ViewBag.IsReadOnly = Model.IsReadOnly;
}

<div class="container-fluid mt-3">
    @await Html.PartialAsync("_CaseEntryTabs")

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Upload Attachment</strong>
        </div>

        <div class="card-body">
            <form asp-controller="PvCaseEntry"
                  asp-action="UploadAttachment"
                  method="post"
                  enctype="multipart/form-data"
                  autocomplete="off">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="PvCaseId" />
                <input type="hidden" asp-for="CaseNo" />
                @if (Model.IsReadOnly)
                {
                    <div class="alert alert-warning">
                        This case is read-only. Attachment upload is disabled.
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <fieldset disabled="@Model.IsReadOnly">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="AttachmentType" class="form-label">
                            Attachment Type <span class="text-danger">*</span>
                        </label>

                        <select asp-for="AttachmentType" class="form-select">
                            <option value="">-- Select Attachment Type --</option>
                            <option>ADR Form</option>
                            <option>Prescription</option>
                            <option>Discharge Summary</option>
                            <option>Lab Report</option>
                            <option>Medical Record</option>
                            <option>Email Communication</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="AttachmentType" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label asp-for="File" class="form-label">
                            File <span class="text-danger">*</span>
                        </label>

                        <input asp-for="File"
                               type="file"
                               class="form-control"
                               accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />

                        <span asp-validation-for="File" class="text-danger small"></span>

                        <small class="text-muted">
                            Allowed files: PDF, JPG, JPEG, PNG, DOC, DOCX, XLS, XLSX. Maximum size: 10 MB.
                        </small>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label">Description</label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Enter attachment description"></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
                </fieldset>

                @if (!Model.IsReadOnly)
                {
                    <button type="submit" class="btn btn-primary">
                        Upload
                    </button>
                }

                <a asp-controller="PvCaseEntry"
                   asp-action="Attachments"
                   asp-route-caseId="@Model.PvCaseId"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}