@model InnoPV.Web.Models.RegulatorySubmission.RegulatorySubmissionCreateViewModel

@{
    ViewData["Title"] = "Create Regulatory Submission";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Create Regulatory Submission</h3>
            <p class="text-muted mb-0">
                Case No: <strong>@Model.CaseNo</strong>
            </p>
        </div>

        <a asp-controller="RegulatorySubmission"
           asp-action="Index"
           asp-route-caseId="@Model.PvCaseId"
           class="btn btn-outline-secondary">
            Back
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Submission Details</strong>
        </div>

        <div class="card-body">
            <form asp-controller="RegulatorySubmission"
                  asp-action="Create"
                  method="post"
                  enctype="multipart/form-data"
                  autocomplete="off">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="PvCaseId" />
                <input type="hidden" asp-for="CaseNo" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="SubmissionType" class="form-label">
                            Submission Type <span class="text-danger">*</span>
                        </label>

                        <select asp-for="SubmissionType" class="form-select">
                            <option value="">-- Select --</option>
                            <option>Initial Submission</option>
                            <option>Follow-up Submission</option>
                            <option>Final Submission</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="SubmissionType" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="RecipientAuthority" class="form-label">
                            Recipient Authority <span class="text-danger">*</span>
                        </label>

                        <select asp-for="RecipientAuthority" class="form-select">
                            <option value="">-- Select --</option>
                            <option>IPC / PvPI</option>
                            <option>CDSCO</option>
                            <option>Sponsor</option>
                            <option>Ethics Committee</option>
                            <option>Regulatory Authority</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="RecipientAuthority" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="SubmissionFormat" class="form-label">
                            Submission Format <span class="text-danger">*</span>
                        </label>

                        <select asp-for="SubmissionFormat" class="form-select">
                            <option value="">-- Select --</option>
                            <option>Email</option>
                            <option>Portal</option>
                            <option>XML</option>
                            <option>PDF</option>
                            <option>Excel</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="SubmissionFormat" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="DueDate" class="form-label">
                            Due Date <span class="text-danger">*</span>
                        </label>

                        <input asp-for="DueDate"
                               asp-format="{0:yyyy-MM-dd}"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="DueDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label asp-for="SubmissionDocument" class="form-label">
                            Submission Document
                        </label>

                        <input asp-for="SubmissionDocument"
                               type="file"
                               class="form-control"
                               accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />

                        <small class="text-muted">
                            Allowed: PDF, image, Word, Excel. Max size: 10 MB.
                        </small>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Remarks" class="form-label">Remarks</label>

                        <textarea asp-for="Remarks"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Enter submission remarks"></textarea>

                        <span asp-validation-for="Remarks" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Save Submission
                </button>

                <a asp-controller="RegulatorySubmission"
                   asp-action="Index"
                   asp-route-caseId="@Model.PvCaseId"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}