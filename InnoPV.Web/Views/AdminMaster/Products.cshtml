@model List<InnoPV.Web.Models.Admin.ProductMasterViewModel>

@{
    ViewData["Title"] = "Product Master";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Product Master</h3>
            <p class="text-muted mb-0">
                Manage product/drug details for PV case processing.
            </p>
        </div>

        <div>
            <a asp-controller="AdminMaster"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

            <a asp-controller="AdminMaster"
               asp-action="CreateProduct"
               class="btn btn-primary">
                + Add Product
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Product List</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Product Name</th>
                        <th>Generic Name</th>
                        <th>Product Code</th>
                        <th>Product Type</th>
                        <th>Strength</th>
                        <th>Dosage Form</th>
                        <th>Manufacturer</th>
                        <th style="width:100px;">Status</th>
                        <th style="width:190px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        var index = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.ProductName</td>
                                <td>@item.GenericName</td>
                                <td>@item.ProductCode</td>
                                <td>@item.ProductType</td>
                                <td>@item.Strength</td>
                                <td>@item.DosageForm</td>
                                <td>@item.ManufacturerName</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="AdminMaster"
                                       asp-action="EditProduct"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <form asp-controller="AdminMaster"
                                          asp-action="ToggleProductStatus"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to change this product status?');">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" class="btn btn-sm btn-outline-warning">
                                            @(item.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted">
                                No product records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>