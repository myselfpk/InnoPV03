@model List<InnoPV.Web.Models.Admin.SponsorMasterViewModel>

@{
    ViewData["Title"] = "Sponsor Master";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Sponsor Master</h3>
            <p class="text-muted mb-0">
                Manage sponsor, client, MAH or partner details.
            </p>
        </div>

        <div>
            <a asp-controller="AdminMaster"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

            <a asp-controller="AdminMaster"
               asp-action="CreateSponsor"
               class="btn btn-primary">
                + Add Sponsor
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Sponsor List</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Sponsor Name</th>
                        <th>Sponsor Code</th>
                        <th>Contact Person</th>
                        <th>Contact Email</th>
                        <th>Contact Phone</th>
                        <th style="width:100px;">Status</th>
                        <th style="width:190px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        var index = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.SponsorName</td>
                                <td>@item.SponsorCode</td>
                                <td>@item.ContactPerson</td>
                                <td>@item.ContactEmail</td>
                                <td>@item.ContactPhone</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="AdminMaster"
                                       asp-action="EditSponsor"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <form asp-controller="AdminMaster"
                                          asp-action="ToggleSponsorStatus"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to change this sponsor status?');">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" class="btn btn-sm btn-outline-warning">
                                            @(item.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                No sponsor records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>