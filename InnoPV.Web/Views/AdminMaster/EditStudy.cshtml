@model InnoPV.Web.Models.Admin.StudyMasterViewModel

@{
    ViewData["Title"] = "Edit Study";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Edit Study</h3>
            <p class="text-muted mb-0">
                Update existing study/protocol details.
            </p>
        </div>

        <a asp-controller="AdminMaster"
           asp-action="Studies"
           class="btn btn-outline-secondary">
            Back
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Study Details</strong>
        </div>

        <div class="card-body">
            <form asp-controller="AdminMaster"
                  asp-action="EditStudy"
                  method="post"
                  autocomplete="off">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                @await Html.PartialAsync("_StudyForm", Model)

                <button type="submit" class="btn btn-primary">
                    Update
                </button>

                <a asp-controller="AdminMaster"
                   asp-action="Studies"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}