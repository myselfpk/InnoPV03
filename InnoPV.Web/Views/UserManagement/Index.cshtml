@model List<InnoPV.Web.Models.UserManagement.UserListItemViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>User Management</h3>
            <p class="text-muted mb-0">
                Create, update and share user credentials.
            </p>
        </div>

        <a asp-controller="UserManagement"
           asp-action="Create"
           class="btn btn-primary">
            + Create User
        </a>
    </div>

    <partial name="_TempDataAlerts" />

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>User List</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Mobile No</th>
                        <th>Designation</th>
                        <th>Department</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Must Change Password</th>
                        <th style="width:260px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        var index = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@index</td>

                                <td>@item.FullName</td>

                                <td>@item.Email</td>

                                <td>@item.MobileNo</td>

                                <td>@item.Designation</td>

                                <td>@item.Department</td>

                                <td>
                                    <span class="badge bg-info text-dark">
                                        @item.Role
                                    </span>
                                </td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>

                                <td>
                                    @if (item.MustChangePassword)
                                    {
                                        <span class="badge bg-warning text-dark">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">No</span>
                                    }
                                </td>

                                <td>
                                    <a asp-controller="UserManagement"
                                       asp-action="Edit"
                                       asp-route-id="@item.UserId"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <form asp-controller="UserManagement"
                                          asp-action="ShareCredentials"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('This will reset the password and email new temporary credentials to the user. Continue?');">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.UserId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-success">
                                            Share Credentials
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted">
                                No users found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>