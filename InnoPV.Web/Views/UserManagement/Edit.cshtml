@model InnoPV.Web.Models.UserManagement.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Edit User</h3>
            <p class="text-muted mb-0">
                Update user profile, role and active status.
            </p>
        </div>

        <a asp-controller="UserManagement"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Back
        </a>
    </div>

    <partial name="_TempDataAlerts" />

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>User Details</strong>
        </div>

        <div class="card-body">
            <form asp-controller="UserManagement"
                  asp-action="Edit"
                  method="post"
                  autocomplete="off">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="UserId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="FullName" class="form-label">
                            Full Name <span class="text-danger">*</span>
                        </label>

                        <input asp-for="FullName"
                               class="form-control" />

                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Email" class="form-label">
                            Email <span class="text-danger">*</span>
                        </label>

                        <input asp-for="Email"
                               class="form-control" />

                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="MobileNo" class="form-label">
                            Mobile No <span class="text-danger">*</span>
                        </label>

                        <input asp-for="MobileNo"
                               class="form-control" />

                        <span asp-validation-for="MobileNo" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Designation" class="form-label">
                            Designation
                        </label>

                        <input asp-for="Designation"
                               class="form-control" />

                        <span asp-validation-for="Designation" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Department" class="form-label">
                            Department
                        </label>

                        <input asp-for="Department"
                               class="form-control" />

                        <span asp-validation-for="Department" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Role" class="form-label">
                            Role <span class="text-danger">*</span>
                        </label>

                        <select asp-for="Role"
                                asp-items="Model.RoleOptions"
                                class="form-select">
                            <option value="">-- Select Role --</option>
                        </select>

                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="form-check mt-4">
                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                                Active User
                            </label>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="form-check mt-4">
                            <input asp-for="MustChangePassword"
                                   class="form-check-input" />

                            <label asp-for="MustChangePassword"
                                   class="form-check-label">
                                Must Change Password
                            </label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Update User
                </button>

                <a asp-controller="UserManagement"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}