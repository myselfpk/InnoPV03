@model InnoPV.Web.Models.Dashboard.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";

    var openPercent = Model.TotalCases == 0 ? 0 : (int)Math.Round((double)Model.OpenCases * 100 / Model.TotalCases);
    var validPercent = Model.TotalCases == 0 ? 0 : (int)Math.Round((double)Model.ValidCases * 100 / Model.TotalCases);
    var activeUserPercent = Model.TotalUsers == 0 ? 0 : (int)Math.Round((double)Model.ActiveUsers * 100 / Model.TotalUsers);
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-1">Admin Dashboard</h3>
            <p class="text-muted mb-0">
                System control center for users, PV operations, master data and reporting.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="UserManagement"
               asp-action="Create"
               class="btn btn-primary">
                Create User
            </a>

            <a asp-controller="PvCase"
               asp-action="Create"
               class="btn btn-outline-primary">
                New Case
            </a>

            <a asp-controller="PvDashboard"
               asp-action="Index"
               class="btn btn-outline-secondary">
                PV Dashboard
            </a>
        </div>
    </div>

    <partial name="_TempDataAlerts" />

    <div class="row g-3 mb-3">
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 border-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted">Users</h6>
                            <h2 class="mb-0">@Model.TotalUsers</h2>
                        </div>
                        <span class="badge bg-primary">@activeUserPercent% active</span>
                    </div>

                    <div class="progress mt-3" style="height:6px;">
                        <div class="progress-bar"
                             role="progressbar"
                             style="width:@activeUserPercent%"></div>
                    </div>

                    <div class="small text-muted mt-2">
                        @Model.ActiveUsers active, @Model.InactiveUsers inactive
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 border-info">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted">PV Cases</h6>
                            <h2 class="mb-0">@Model.TotalCases</h2>
                        </div>
                        <span class="badge bg-info text-dark">@openPercent% open</span>
                    </div>

                    <div class="progress mt-3" style="height:6px;">
                        <div class="progress-bar bg-info"
                             role="progressbar"
                             style="width:@openPercent%"></div>
                    </div>

                    <div class="small text-muted mt-2">
                        @Model.OpenCases open, @Model.ClosedCases closed
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 border-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted">Validity</h6>
                            <h2 class="mb-0">@Model.ValidCases</h2>
                        </div>
                        <span class="badge bg-success">@validPercent% valid</span>
                    </div>

                    <div class="progress mt-3" style="height:6px;">
                        <div class="progress-bar bg-success"
                             role="progressbar"
                             style="width:@validPercent%"></div>
                    </div>

                    <div class="small text-muted mt-2">
                        @Model.InvalidCases invalid / follow-up cases
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 border-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted">Overdue</h6>
                            <h2 class="mb-0 text-danger">@Model.OverdueCases</h2>
                        </div>
                        <span class="badge bg-danger">@Model.SeriousCases serious</span>
                    </div>

                    <div class="small text-muted mt-3">
                        Open cases that crossed due date need immediate review.
                    </div>

                    <a asp-controller="CaseReport"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-danger mt-3">
                        Review Cases
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>Administration</strong>
                </div>

                <div class="list-group list-group-flush">
                    <a asp-controller="UserManagement"
                       asp-action="Index"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        User Management
                        <span class="badge bg-primary rounded-pill">@Model.TotalUsers</span>
                    </a>

                    <a asp-controller="AdminMaster"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        Master Data
                    </a>

                    <a asp-controller="AdminChecklist"
                       asp-action="Index"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        Checklist Master
                        <span class="badge bg-primary rounded-pill">@Model.Checklists</span>
                    </a>

                    <a asp-controller="SlaAlert"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        SLA Alerts
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>PV Operations</strong>
                </div>

                <div class="list-group list-group-flush">
                    <a asp-controller="CaseInbox"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        My Inbox
                    </a>

                    <a asp-controller="PvCase"
                       asp-action="Index"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        PV Cases
                        <span class="badge bg-primary rounded-pill">@Model.TotalCases</span>
                    </a>

                    <a asp-controller="CaseAssignment"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        Case Assignment
                    </a>

                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        Regulatory Submissions
                        <span class="badge bg-secondary rounded-pill">@Model.Submissions</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>Reports</strong>
                </div>

                <div class="list-group list-group-flush">
                    <a asp-controller="CaseReport"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        Case Report
                    </a>

                    <a asp-controller="CaseCompleteReport"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        Complete Case Report
                    </a>

                    <a asp-controller="RegulatorySubmissionReport"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        Submission Report
                    </a>

                    <a asp-controller="CaseCompleteReport"
                       asp-action="Index"
                       class="list-group-item list-group-item-action">
                        Export Center
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <strong>Recent Cases</strong>

                    <a asp-controller="PvCase"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-primary">
                        View All
                    </a>
                </div>

                <div class="card-body table-responsive">
                    <table class="table table-bordered table-striped align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Case No</th>
                                <th>Product</th>
                                <th>Event</th>
                                <th>Status</th>
                                <th>Due Date</th>
                                <th style="width:90px;">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.RecentCases.Any())
                            {
                                foreach (var item in Model.RecentCases)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.CaseNo</strong>
                                            <div class="small text-muted">
                                                @item.CreatedOnUtc.ToString("dd-MMM-yyyy")
                                            </div>
                                        </td>
                                        <td>@item.ProductName</td>
                                        <td>@item.EventTerm</td>
                                        <td>
                                            <span class="badge bg-info text-dark">@item.Status</span>
                                        </td>
                                        <td>
                                            @(item.DueDate.HasValue ? item.DueDate.Value.ToString("dd-MMM-yyyy") : "-")
                                        </td>
                                        <td>
                                            <a asp-controller="PvCase"
                                               asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        No recent cases found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>Case Status</strong>
                </div>

                <div class="card-body">
                    @if (Model.CasesByStatus.Any())
                    {
                        foreach (var item in Model.CasesByStatus)
                        {
                            var statusPercent = Model.TotalCases == 0
                                ? 0
                                : (int)Math.Round((double)item.Count * 100 / Model.TotalCases);

                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@item.Label</span>
                                    <strong>@item.Count</strong>
                                </div>
                                <div class="progress" style="height:6px;">
                                    <div class="progress-bar"
                                         role="progressbar"
                                         style="width:@statusPercent%"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted">No case status data available.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>Master Data Health</strong>
                </div>

                <div class="card-body">
                    <div class="row g-3 text-center">
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="text-muted small">Products</div>
                                <h4 class="mb-0">@Model.Products</h4>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="text-muted small">Sponsors</div>
                                <h4 class="mb-0">@Model.Sponsors</h4>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="text-muted small">Studies</div>
                                <h4 class="mb-0">@Model.Studies</h4>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="text-muted small">Checklists</div>
                                <h4 class="mb-0">@Model.Checklists</h4>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <a asp-controller="AdminMaster"
                           asp-action="Index"
                           class="btn btn-sm btn-outline-primary">
                            Manage Masters
                        </a>

                        <a asp-controller="AdminChecklist"
                           asp-action="Index"
                           class="btn btn-sm btn-outline-secondary">
                            Manage Checklists
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>Users by Role</strong>
                </div>

                <div class="card-body">
                    @foreach (var item in Model.UsersByRole)
                    {
                        var rolePercent = Model.TotalUsers == 0
                            ? 0
                            : (int)Math.Round((double)item.Count * 100 / Model.TotalUsers);

                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>@item.Label</span>
                                <strong>@item.Count</strong>
                            </div>
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar bg-secondary"
                                     role="progressbar"
                                     style="width:@rolePercent%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <strong>Recent Users</strong>

                    <a asp-controller="UserManagement"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-primary">
                        Manage
                    </a>
                </div>

                <div class="list-group list-group-flush">
                    @if (Model.RecentUsers.Any())
                    {
                        foreach (var item in Model.RecentUsers)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between gap-2">
                                    <div>
                                        <strong>@item.Name</strong>
                                        <div class="small text-muted">@item.Email</div>
                                    </div>

                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success align-self-start">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary align-self-start">Inactive</span>
                                    }
                                </div>
                                <div class="small text-muted mt-1">
                                    Created @item.CreatedOnUtc.ToString("dd-MMM-yyyy")
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted">
                            No users found.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
