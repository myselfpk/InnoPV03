@model List<InnoPV.Web.Models.PvCase.PvCaseListItemViewModel>
@using InnoPV.Web.Models.Shared

@{
    ViewData["Title"] = "PV Case List";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>PV Case List</h3>
            <p class="text-muted mb-0">
                View and manage pharmacovigilance case intake records.
            </p>
        </div>

        <a asp-controller="PvCase"
           asp-action="Create"
           class="btn btn-primary">
            + New Case
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Cases</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Case No</th>
                        <th>Source</th>
                        <th>Receipt Date</th>
                        <th>Reporter</th>
                        <th>Patient</th>
                        <th>Product</th>
                        <th>Event</th>
                        <th>Validity</th>
                        <th>Seriousness</th>
                        <th>Completeness</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th style="width:260px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        var index = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>
                                    <strong>@item.CaseNo</strong>
                                </td>
                                <td>@item.CaseSource</td>
                                <td>@item.ReceiptDate.ToString("dd-MMM-yyyy")</td>
                                <td>@item.InitialReporterName</td>
                                <td>@item.InitialPatientIdentifier</td>
                                <td>@item.InitialProductName</td>
                                <td>@item.InitialEventTerm</td>
                                <td>
                                    @if (item.IsValidCase)
                                    {
                                        <span class="badge bg-success">Valid</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Invalid</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsSerious)
                                    {
                                        <span class="badge bg-danger">Serious</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Non-serious</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-primary">
                                        @item.CompletenessScore%
                                    </span>
                                </td>
                                <td>
                                    @(item.DueDate.HasValue ? item.DueDate.Value.ToString("dd-MMM-yyyy") : "-")
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @item.Status
                                    </span>
                                </td>
                                <td>
                                    <partial name="_PvCaseActionButtons"
                                             model="new PvCaseActionButtonsViewModel
                                             {
                                                 PvCaseId = item.Id,
                                                  ShowView = true,
                                                  ShowEdit = true,
                                                  ShowEntry = true,
                                                  ShowHistory = true,
                                                  ShowDuplicate = true
                                              }" />
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="14" class="text-center text-muted">
                                No PV case records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
