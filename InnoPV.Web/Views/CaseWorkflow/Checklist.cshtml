@model InnoPV.Web.Models.Workflow.CaseChecklistCaptureViewModel

@{
    ViewData["Title"] = "Workflow Checklist";

    var submitButtonText = "Submit";
    var isReadOnly = Convert.ToBoolean(ViewBag.IsReadOnly ?? false);

    if (Model.ApplicableRole == InnoPV.Domain.Identity.AppRoles.PvAssociate)
    {
        submitButtonText = "Submit to PV Manager";
    }
    else if (Model.ApplicableRole == InnoPV.Domain.Identity.AppRoles.PvManager)
    {
        submitButtonText = "Forward to Medical Reviewer";
    }
    else if (Model.ApplicableRole == InnoPV.Domain.Identity.AppRoles.MedicalReviewer)
    {
        submitButtonText = "Close Case";
    }

    var allowReturn = Model.ApplicableRole == InnoPV.Domain.Identity.AppRoles.PvManager
                      || Model.ApplicableRole == InnoPV.Domain.Identity.AppRoles.MedicalReviewer;
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Workflow Checklist</h3>
            <p class="text-muted mb-0">
                Case No: <strong>@Model.CaseNo</strong> |
                Role: <strong>@Model.ApplicableRole</strong> |
                Stage: <strong>@Model.ApplicableStage</strong>
            </p>
        </div>

        <div>
            <a asp-controller="PvCaseEntry"
               asp-action="Patient"
               asp-route-caseId="@Model.PvCaseId"
               class="btn btn-outline-success">
                Case Entry
            </a>

            <a asp-controller="PvCase"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back to Case List
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <strong>Case Workflow Summary</strong>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Case No:</strong>
                    <div>@Model.CaseNo</div>
                </div>

                <div class="col-md-3">
                    <strong>Current Status:</strong>
                    <div>
                        <span class="badge bg-info text-dark">
                            @Model.CurrentStatus
                        </span>
                    </div>
                </div>

                <div class="col-md-3">
                    <strong>Applicable Role:</strong>
                    <div>@Model.ApplicableRole</div>
                </div>

                <div class="col-md-3">
                    <strong>Checklist:</strong>
                    <div>@Model.ChecklistName</div>
                </div>
            </div>
        </div>
    </div>

    <form asp-controller="CaseWorkflow"
          asp-action="SaveChecklist"
          method="post"
          autocomplete="off">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="PvCaseId" />
        <input type="hidden" asp-for="CaseNo" />
        <input type="hidden" asp-for="CurrentStatus" />
        <input type="hidden" asp-for="ApplicableRole" />
        <input type="hidden" asp-for="ApplicableStage" />
        <input type="hidden" asp-for="ChecklistMasterId" />
        <input type="hidden" asp-for="ChecklistName" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <strong>@Model.ChecklistName</strong>
            </div>

            <div class="card-body table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Checklist Item</th>
                            <th style="width:130px;">Mandatory</th>
                            <th style="width:120px;">Checked</th>
                            <th style="width:350px;">Remarks</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Items.Any())
                        {
                            for (var i = 0; i < Model.Items.Count; i++)
                            {
                                <tr>
                                    <td>
                                        @(i + 1)

                                        <input type="hidden" asp-for="Items[i].ChecklistItemId" />
                                        <input type="hidden" asp-for="Items[i].ItemText" />
                                        <input type="hidden" asp-for="Items[i].IsMandatory" />
                                        <input type="hidden" asp-for="Items[i].DisplayOrder" />
                                    </td>

                                    <td>
                                        @Model.Items[i].ItemText

                                        @if (Model.Items[i].IsMandatory)
                                        {
                                            <span class="text-danger">*</span>
                                        }
                                    </td>

                                    <td>
                                        @if (Model.Items[i].IsMandatory)
                                        {
                                            <span class="badge bg-danger">Mandatory</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Optional</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="form-check d-flex justify-content-center">
                                            <input asp-for="Items[i].IsChecked"
                                                   class="form-check-input"
                                                   disabled="@isReadOnly"
                                                   style="width:22px;height:22px;" />
                                        </div>
                                    </td>

                                    <td>
                                        <input asp-for="Items[i].Remarks"
                                               class="form-control"
                                               disabled="@isReadOnly"
                                               placeholder="Enter remarks, if any" />

                                        <span asp-validation-for="Items[i].Remarks"
                                              class="text-danger small"></span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    No active checklist items found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm mt-3">
            <div class="card-header bg-light">
                <strong>Workflow Comment</strong>
            </div>

            <div class="card-body">
                <label asp-for="WorkflowComment" class="form-label">
                    Comment
                </label>

                <textarea asp-for="WorkflowComment"
                          class="form-control"
                          rows="3"
                          disabled="@isReadOnly"
                          placeholder="Enter submit/forward/closure comment, if required"></textarea>

                <span asp-validation-for="WorkflowComment" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-3">
            @if (!isReadOnly)
            {
                <button type="submit"
                        class="btn btn-outline-primary">
                    Save Checklist
                </button>

                <button type="submit"
                        class="btn btn-primary"
                        formaction="@Url.Action("SubmitToNextRole", "CaseWorkflow")"
                        formmethod="post"
                        onclick="return confirm('Are you sure you want to submit this case to the next workflow stage?');">
                    @submitButtonText
                </button>
            }
            else
            {
                <div class="alert alert-warning mt-3">
                    This case is read-only. Checklist cannot be modified.
                </div>
            }

            @if (allowReturn && !isReadOnly)
            {
                <a asp-controller="CaseWorkflow"
                   asp-action="Return"
                   asp-route-caseId="@Model.PvCaseId"
                   class="btn btn-outline-danger">
                    Return Case
                </a>
            }
            @if (Model.ApplicableRole == InnoPV.Domain.Identity.AppRoles.MedicalReviewer)
            {
                <a asp-controller="CaseClosure"
                   asp-action="Validate"
                   asp-route-caseId="@Model.PvCaseId"
                   class="btn btn-outline-info">
                    Closure Validation
                </a>
            }

            <a asp-controller="PvCase"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}