@model InnoPV.Web.Models.CaseInbox.CaseInboxViewModel
@using InnoPV.Web.Models.Shared

@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>@Model.PageTitle</h3>
            <p class="text-muted mb-0">
                Role: <strong>@Model.UserRole</strong>
            </p>
        </div>

        <a asp-controller="PvCase"
           asp-action="Create"
           class="btn btn-primary">
            + New Case
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row g-3 mb-3">
        <div class="col-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Total</h6>
                    <h3>@Model.TotalCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Open</h6>
                    <h3>@Model.OpenCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Closed</h6>
                    <h3>@Model.ClosedCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Serious</h6>
                    <h3>@Model.SeriousCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Overdue</h6>
                    <h3>@Model.OverdueCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Returned</h6>
                    <h3>@Model.ReturnedCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Case Inbox</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Case No</th>
                        <th>Source</th>
                        <th>Receipt Date</th>
                        <th>Reporter</th>
                        <th>Patient</th>
                        <th>Product</th>
                        <th>Event</th>
                        <th>Validity</th>
                        <th>Seriousness</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Assigned Role</th>
                        <th style="width:760px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Cases.Any())
                    {
                        var index = 1;

                        foreach (var item in Model.Cases)
                        {
                            <tr>
                                <td>@index</td>

                                <td>
                                    <strong>@item.CaseNo</strong>
                                </td>

                                <td>@item.CaseSource</td>

                                <td>@item.ReceiptDate.ToString("dd-MMM-yyyy")</td>

                                <td>@item.InitialReporterName</td>

                                <td>@item.InitialPatientIdentifier</td>

                                <td>@item.InitialProductName</td>

                                <td>@item.InitialEventTerm</td>

                                <td>
                                    @if (item.IsValidCase)
                                    {
                                        <span class="badge bg-success">Valid</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Invalid</span>
                                    }
                                </td>

                                <td>
                                    @if (item.IsSerious)
                                    {
                                        <span class="badge bg-danger">Serious</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Non-serious</span>
                                    }
                                </td>

                                <td>
                                    @if (item.DueDate.HasValue)
                                    {
                                        if (item.IsOverdue)
                                        {
                                            <span class="badge bg-danger">
                                                @item.DueDate.Value.ToString("dd-MMM-yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span>@item.DueDate.Value.ToString("dd-MMM-yyyy")</span>
                                        }
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge bg-info text-dark">
                                        @item.Status
                                    </span>
                                </td>

                                <td>@item.CurrentAssignedRole</td>

                                <td>
                                    <partial name="_PvCaseActionButtons"
                                             model="new PvCaseActionButtonsViewModel
                                             {
                                                 PvCaseId = item.Id,
                                                 ShowView = true,
                                                 ShowEntry = true,
                                                 ShowChecklist = true,
                                                 ShowHistory = true,
                                                 ShowDuplicate = true,
                                                 ShowFollowUp = true,
                                                 ShowSubmission = true,
                                                 ShowAssign = true,
                                                 ShowClosure = true
                                             }" />
</td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="14" class="text-center text-muted">
                                No cases available in your inbox.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
