@model InnoPV.Web.Models.ClosureValidation.CaseClosureValidationViewModel

@{
    ViewData["Title"] = "Case Closure Validation";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Case Closure Validation</h3>
            <p class="text-muted mb-0">
                Case No: <strong>@Model.CaseNo</strong>
            </p>
        </div>

        <div>
            <a asp-controller="CaseWorkflow"
               asp-action="Checklist"
               asp-route-caseId="@Model.PvCaseId"
               class="btn btn-outline-warning">
                Back to Checklist
            </a>

            <a asp-controller="PvCaseEntry"
               asp-action="Patient"
               asp-route-caseId="@Model.PvCaseId"
               class="btn btn-outline-success">
                Case Entry
            </a>

            <a asp-controller="CaseInbox"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back to Inbox
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <strong>Validation Summary</strong>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Case No:</strong>
                    <div>@Model.CaseNo</div>
                </div>

                <div class="col-md-3">
                    <strong>Status:</strong>
                    <div>
                        <span class="badge bg-info text-dark">@Model.Status</span>
                    </div>
                </div>

                <div class="col-md-3">
                    <strong>Required Failed:</strong>
                    <div>
                        @if (Model.RequiredFailedCount > 0)
                        {
                            <span class="badge bg-danger">@Model.RequiredFailedCount</span>
                        }
                        else
                        {
                            <span class="badge bg-success">0</span>
                        }
                    </div>
                </div>

                <div class="col-md-3">
                    <strong>Closure Decision:</strong>
                    <div>
                        @if (Model.CanClose)
                        {
                            <span class="badge bg-success">Case can be closed</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Case cannot be closed</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.CanClose)
    {
        <div class="alert alert-danger">
            Case closure is blocked. Please complete all failed required checks before closing the case.
        </div>
    }
    else
    {
        <div class="alert alert-success">
            All required closure checks are completed. Case can be closed from Medical Reviewer checklist screen.
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <strong>Required Closure Checks</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th style="width:180px;">Section</th>
                        <th style="width:260px;">Check</th>
                        <th style="width:120px;">Result</th>
                        <th>Message</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.RequiredChecks.Any())
                    {
                        var index = 1;

                        foreach (var item in Model.RequiredChecks)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.SectionName</td>
                                <td>@item.CheckDescription</td>
                                <td>
                                    @if (item.IsPassed)
                                    {
                                        <span class="badge bg-success">Passed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Failed</span>
                                    }
                                </td>
                                <td>@item.Message</td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                No required checks configured.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <strong>Warnings</strong>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th style="width:180px;">Section</th>
                        <th style="width:260px;">Check</th>
                        <th style="width:120px;">Result</th>
                        <th>Message</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.WarningChecks.Any())
                    {
                        var index = 1;

                        foreach (var item in Model.WarningChecks)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.SectionName</td>
                                <td>@item.CheckDescription</td>
                                <td>
                                    @if (item.IsPassed)
                                    {
                                        <span class="badge bg-success">Passed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Warning</span>
                                    }
                                </td>
                                <td>@item.Message</td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                No warnings found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>