@model InnoPV.Web.Models.Account.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <strong>Forgot Password</strong>
                </div>

                <div class="card-body">
                    <partial name="_TempDataAlerts" />

                    <p class="text-muted">
                        Enter your registered email address. Password reset instructions will be sent to your email.
                    </p>

                    <form asp-controller="Account"
                          asp-action="ForgotPassword"
                          method="post"
                          autocomplete="off">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">
                                Registered Email <span class="text-danger">*</span>
                            </label>

                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Enter your registered email" />

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Send Reset Link
                        </button>

                        <div class="text-center mt-3">
                            <a asp-controller="Account"
                               asp-action="Login">
                                Back to Login
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}