@model InnoPV.Web.Models.Profile.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Change Password</h3>

            @if (Model.IsForcedChange)
            {
                <p class="text-danger mb-0">
                    First login password change is mandatory.
                </p>
            }
            else
            {
                <p class="text-muted mb-0">
                    Update your account password.
                </p>
            }
        </div>

        @if (!Model.IsForcedChange)
        {
            <a asp-controller="Profile"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Back to Profile
            </a>
        }
    </div>

    <partial name="_TempDataAlerts" />

    @if (Model.IsForcedChange)
    {
        <div class="alert alert-warning">
            You have logged in using temporary credentials. Please change your password to continue.
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Password Details</strong>
        </div>

        <div class="card-body">
            <form asp-controller="Profile"
                  asp-action="ChangePassword"
                  method="post"
                  autocomplete="off">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="IsForcedChange" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="CurrentPassword" class="form-label">
                            Current Password <span class="text-danger">*</span>
                        </label>

                        <input asp-for="CurrentPassword"
                               class="form-control"
                               placeholder="Enter current/temporary password" />

                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="NewPassword" class="form-label">
                            New Password <span class="text-danger">*</span>
                        </label>

                        <input asp-for="NewPassword"
                               class="form-control"
                               placeholder="Enter new password" />

                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">
                            Confirm Password <span class="text-danger">*</span>
                        </label>

                        <input asp-for="ConfirmPassword"
                               class="form-control"
                               placeholder="Confirm new password" />

                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="alert alert-info">
                    Password should be at least 8 characters and should meet the system password policy.
                </div>

                <button type="submit" class="btn btn-primary">
                    Change Password
                </button>

                @if (!Model.IsForcedChange)
                {
                    <a asp-controller="Profile"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}