@model InnoPV.Web.Models.CaseFollowUp.CaseFollowUpCreateViewModel

@{
    ViewData["Title"] = "Create Follow-up";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Create Follow-up</h3>
            <p class="text-muted mb-0">
                Case No: <strong>@Model.CaseNo</strong>
            </p>
        </div>

        <a asp-controller="CaseFollowUp"
           asp-action="Index"
           asp-route-caseId="@Model.PvCaseId"
           class="btn btn-outline-secondary">
            Back to Follow-ups
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Follow-up Information</strong>
        </div>

        <div class="card-body">
            <form asp-controller="CaseFollowUp"
                  asp-action="Create"
                  method="post"
                  autocomplete="off">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="PvCaseId" />
                <input type="hidden" asp-for="CaseNo" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="ReceiptDate" class="form-label">
                            Receipt Date <span class="text-danger">*</span>
                        </label>

                        <input asp-for="ReceiptDate"
                               asp-format="{0:yyyy-MM-dd}"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="ReceiptDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Source" class="form-label">
                            Source <span class="text-danger">*</span>
                        </label>

                        <select asp-for="Source" class="form-select">
                            <option value="">-- Select Source --</option>
                            <option>Patient</option>
                            <option>Reporter</option>
                            <option>HCP</option>
                            <option>Site</option>
                            <option>Sponsor</option>
                            <option>Email</option>
                            <option>Phone Call</option>
                            <option>Medical Record</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="Source" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="ReceivedFrom" class="form-label">
                            Received From
                        </label>

                        <input asp-for="ReceivedFrom"
                               class="form-control"
                               placeholder="Name / department / email" />

                        <span asp-validation-for="ReceivedFrom" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label">
                            Follow-up Description <span class="text-danger">*</span>
                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Describe the follow-up information received"></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="AdditionalInformation" class="form-label">
                            Additional Information
                        </label>

                        <textarea asp-for="AdditionalInformation"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Any additional information / action required"></textarea>

                        <span asp-validation-for="AdditionalInformation" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Save Follow-up
                </button>

                <a asp-controller="CaseFollowUp"
                   asp-action="Index"
                   asp-route-caseId="@Model.PvCaseId"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}